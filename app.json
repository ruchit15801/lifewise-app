{
  "expo": {
    "name": "LifeWise",
    "slug": "lifewise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./logo.png",
    "scheme": "lifewise",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B4B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifewise"
    },
    "android": {
      "package": "com.lifewise",
      "permissions": [
        "READ_SMS",
        "RECEIVE_SMS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1E1B4B",
        "foregroundImage": "./logo.png"
      }
    },
    "web": {
      "favicon": "./logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./app.plugin.js",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "618d7114-5c6c-4565-8b63-e9b42be5d5af"
      }
    },
    "owner": "sdfsdf12"
  }
}
