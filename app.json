{
  "expo": {
    "name": "LifeWise",
    "slug": "lifewise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./logo.png",
    "scheme": "lifewise",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B4B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifewise"
    },
    "android": {
      "package": "com.lifewise",
      "adaptiveIcon": {
        "backgroundColor": "#1E1B4B",
        "foregroundImage": "./logo.png"
      }
    },
    "web": {
      "favicon": "./logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
