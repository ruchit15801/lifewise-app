# LifeWise Backend
PORT=5000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=lifewise
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: SMS via Twilio (if not set, OTP is logged to console)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE=+1234567890

# Assistant (Conversly): required for in-app AI assistant
# OPENAI_API_KEY=sk-proj-...
# OPENAI_ASSISTANT_ID=asst_WmTjqjLyo3ki1MFHtqDtal6R

# Frontend: API URL. If not set, app uses 127.0.0.1:5000.
# - Web / same machine: 127.0.0.1:5000
# - Android emulator: 10.0.2.2:5000
# - Physical device: your PC IP e.g. 192.168.1.5:5000
# EXPO_PUBLIC_DOMAIN=127.0.0.1:5000
